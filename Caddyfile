{
	# Coolify terminates TLS upstream — no on-disk certs needed.
	auto_https off
	admin off
	persist_config off
}

:{$PORT:80} {
	root * /srv
	encode zstd gzip

	# Long-cache hashed Vite assets.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Security + Circles host embedding.
	header {
		Content-Security-Policy "frame-ancestors 'self' https://*.gnosis.io https://*.vercel.app https://*.aboutcircles.com"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
		# Allow being framed by the Circles host (legacy header for older UAs).
		-X-Frame-Options
	}

	# Health probe for Coolify.
	respond /healthz 200

	# SPA: serve index.html on unknown routes.
	try_files {path} /index.html
	file_server
}
